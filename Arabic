<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mobile Q-Cards</title>
    <style>
        :root {
            --primary: #6366f1;
            --bg: #f8fafc;
            --text: #1e293b;
        }

        body {
            font-family: -apple-system, system-ui, sans-serif;
            background-color: var(--bg);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            margin: 0;
            overflow: hidden;
        }

        /* Card Container */
        .card-container {
            width: 90%;
            max-width: 400px;
            height: 250px;
            perspective: 1000px;
            cursor: pointer;
        }

        .card {
            width: 100%;
            height: 100%;
            position: relative;
            transition: transform 0.6s;
            transform-style: preserve-3d;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            border-radius: 15px;
        }

        .card.is-flipped {
            transform: rotateY(180deg);
        }

        .card-face {
            position: absolute;
            width: 100%;
            height: 100%;
            backface-visibility: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            box-sizing: border-box;
            border-radius: 15px;
            background: white;
            font-size: 1.5rem;
            text-align: center;
            color: var(--text);
        }

        .card-back {
            background: var(--primary);
            color: white;
            transform: rotateY(180deg);
        }

        /* Controls */
        .controls {
            margin-top: 30px;
            display: flex;
            gap: 20px;
        }

        button {
            padding: 12px 24px;
            font-size: 1rem;
            border: none;
            border-radius: 8px;
            background: var(--primary);
            color: white;
            font-weight: bold;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        button:active {
            transform: scale(0.95);
        }

        .progress {
            margin-top: 15px;
            color: #64748b;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>

    <div class="card-container" onclick="flipCard()">
        <div class="card" id="card">
            <div class="card-face card-front" id="frontText">Question loading...</div>
            <div class="card-face card-back" id="backText">Answer loading...</div>
        </div>
    </div>

    <div class="progress" id="progress">Card 1 of X</div>

    <div class="controls">
        <button onclick="prevCard()">Prev</button>
        <button onclick="nextCard()">Next</button>
    </div>

    <script>
        const deck = [
            { q: "What is the capital of France?", a: "Paris" },
            { q: "What is 2 + 2?", a: "4" },
            { q: "Which planet is known as the Red Planet?", a: "Mars" },
            { q: "What is the boiling point of water?", a: "100°C" }
        ];

        let currentIndex = 0;
        const card = document.getElementById('card');
        const front = document.getElementById('frontText');
        const back = document.getElementById('backText');
        const progress = document.getElementById('progress');

        function updateCard() {
            // Reset flip before changing text
            card.classList.remove('is-flipped');
            
            setTimeout(() => {
                front.innerText = deck[currentIndex].q;
                back.innerText = deck[currentIndex].a;
                progress.innerText = `Card ${currentIndex + 1} of ${deck.length}`;
            }, 150); 
        }

        function flipCard() {
            card.classList.toggle('is-flipped');
        }

        function nextCard() {
            currentIndex = (currentIndex + 1) % deck.length;
            updateCard();
        }

        function prevCard() {
            currentIndex = (currentIndex - 1 + deck.length) % deck.length;
            updateCard();
        }

        // Initialize
        updateCard();
    </script>
</body>
</html>
